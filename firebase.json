{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "apphosting.yaml",
      "README.md",
      ".vscode/**",
      "node_modules/**",
      ".env",
      ".git/**"
    ],
    "frameworksBackend": {
      "region": "us-central1"
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
