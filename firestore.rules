rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function getClaim(key) {
      return request.auth.token[key];
    }

    function tenantId() {
      return getClaim('tenantId');
    }

    function userRole() {
      return getClaim('role');
    }

    function isOwner() {
      return getClaim('isOwner') == true || userRole() == 'owner';
    }

    function isAdmin() {
      return getClaim('isAdmin') == true || userRole() == 'admin' || isOwner();
    }

    function isManager() {
      return userRole() == 'manager' || isAdmin();
    }

    function isDriver() {
      return userRole() == 'driver' || isManager();
    }

    function belongsToTenant(tid) {
      return isSignedIn() && tenantId() == tid;
    }

    function isTenantOwner(tid) {
      return belongsToTenant(tid) && isOwner();
    }

    function isTenantAdmin(tid) {
      return belongsToTenant(tid) && isAdmin();
    }

    function isTenantManager(tid) {
      return belongsToTenant(tid) && isManager();
    }

    function isTenantMember(tid) {
      return belongsToTenant(tid);
    }

    function isOwnResource(uid) {
      return isSignedIn() && currentUid() == uid;
    }

    function validTenantWrite(tid) {
      return request.resource.data.tenantId == tid;
    }

    // ── Tenants ───────────────────────────────────────────────────────────

    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow create: if isSignedIn(); // restricted server-side
      allow update: if isTenantAdmin(tenantId);
      allow delete: if isTenantOwner(tenantId);

      // ── Members subcollection ─────────────────────────────────────────

      match /members/{userId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantAdmin(tenantId);
        allow update: if isTenantAdmin(tenantId) || isOwnResource(userId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Invites subcollection ─────────────────────────────────────────

      match /invites/{inviteId} {
        allow read: if isTenantAdmin(tenantId);
        allow create: if isTenantAdmin(tenantId) || isTenantManager(tenantId);
        allow update: if isTenantAdmin(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Trips ─────────────────────────────────────────────────────────

      match /trips/{tripId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantManager(tenantId)
          && validTenantWrite(tenantId);
        allow update: if isTenantManager(tenantId)
          || (isTenantMember(tenantId)
              && resource.data.assignedDriverId == currentUid());
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Vehicles / Fleet ──────────────────────────────────────────────

      match /vehicles/{vehicleId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantManager(tenantId)
          && validTenantWrite(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Drivers ───────────────────────────────────────────────────────

      match /drivers/{driverId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantManager(tenantId)
          && validTenantWrite(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Customers ─────────────────────────────────────────────────────

      match /customers/{customerId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantManager(tenantId)
          && validTenantWrite(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Invoices ──────────────────────────────────────────────────────

      match /invoices/{invoiceId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantManager(tenantId)
          && validTenantWrite(tenantId);
        allow update: if isTenantAdmin(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Expenses ──────────────────────────────────────────────────────

      match /expenses/{expenseId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId)
          && validTenantWrite(tenantId)
          && request.resource.data.submittedBy == currentUid();
        allow update: if isTenantManager(tenantId)
          || (isTenantMember(tenantId)
              && resource.data.submittedBy == currentUid()
              && resource.data.status == 'draft');
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Employees / HR ────────────────────────────────────────────────

      match /employees/{employeeId} {
        allow read: if isTenantManager(tenantId)
          || isOwnResource(employeeId);
        allow write: if isTenantAdmin(tenantId)
          && validTenantWrite(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      match /leaveRequests/{requestId} {
        allow read: if isTenantManager(tenantId)
          || resource.data.employeeId == currentUid();
        allow create: if isTenantMember(tenantId)
          && validTenantWrite(tenantId)
          && request.resource.data.employeeId == currentUid();
        allow update: if isTenantManager(tenantId)
          || (resource.data.employeeId == currentUid()
              && resource.data.status == 'pending');
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Fuel Logs ─────────────────────────────────────────────────────

      match /fuelLogs/{logId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId)
          && validTenantWrite(tenantId);
        allow update: if isTenantManager(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Notes ─────────────────────────────────────────────────────────

      match /notes/{noteId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId)
          && validTenantWrite(tenantId);
        allow update: if isTenantMember(tenantId)
          && (resource.data.authorId == currentUid()
              || isTenantAdmin(tenantId));
        allow delete: if isTenantAdmin(tenantId)
          || resource.data.authorId == currentUid();
      }

      // ── GPS Tracking Events ───────────────────────────────────────────

      match /trackingEvents/{eventId} {
        allow read: if isTenantManager(tenantId);
        allow create: if isTenantMember(tenantId)
          && validTenantWrite(tenantId);
        allow update, delete: if isTenantAdmin(tenantId);
      }
    }

    // ── User-Tenant mappings (read-only for users) ────────────────────────

    match /userTenants/{mappingId} {
      allow read: if isSignedIn()
        && (resource.data.userId == currentUid() || isAdmin());
      allow write: if false; // Only writable server-side
    }

    // ── Invite tokens (write-once lookup) ─────────────────────────────────

    match /inviteTokens/{token} {
      allow read: if isSignedIn();
      allow write: if false; // Only writable server-side
    }
  }
}
