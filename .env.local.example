# ============================================================
# LogisticsVisionBeta - Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in the actual values.
# NEVER commit .env.local to version control.
#
# NOTE: Client-side Firebase config keys (NEXT_PUBLIC_*) are
# safe to expose — they are restricted by Firestore/Storage
# security rules and are required in the browser bundle.
# ============================================================

# --- Firebase Client-Side Configuration -------------------
# Found in: Firebase Console > Project Settings > General > Your Apps
# Also located in src/lib/firebase.ts

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=logisticsvisionbeta.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=logisticsvisionbeta
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=logisticsvisionbeta.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=986370783795
NEXT_PUBLIC_FIREBASE_APP_ID=1:986370783795:web:...
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-...

# --- Firebase Admin SDK (Server-side only) ----------------
# Path to your service account JSON file (for API routes / Node.js scripts)
# Download from: Firebase Console > Project Settings > Service Accounts
# > Generate new private key
# WARNING: Never expose this file or path in client-side code

FIREBASE_ADMIN_SDK_PATH=./service-account.json

# --- Google AI / Genkit -----------------------------------------------
# Used by Genkit @genkit-ai/googleai integration for AI features
# Get from: https://aistudio.google.com/app/apikey

GOOGLE_AI_API_KEY=AIzaSy...
